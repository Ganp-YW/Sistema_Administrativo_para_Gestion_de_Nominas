<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="768.0" prefWidth="1024.0" stylesheets="@../Styles/table.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.PrincipalView">
    
    <top>
        <VBox spacing="15.0" style="-fx-background-color: #181818; -fx-padding: 20; -fx-border-color: #333333; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
            
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Button onAction="#loadDefaultTab" style="-fx-background-color: gray; -fx-text-fill: #E0E0E0; -fx-font-size: 20px; -fx-cursor: hand;" text="←" />
                <Label style="-fx-text-fill: #E0E0E0; -fx-font-size: 18px; -fx-font-weight: bold;" text="Sistema Administrativo para Gestión de Nóminas" />
            </HBox>
            
            <Separator style="-fx-background-color: transparent; -fx-border-color: #333333; -fx-border-width: 1 0 0 0;" />
            
            <HBox alignment="CENTER" prefHeight="35.0" spacing="15.0">
                <Button onAction="#loadProvidersTab" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #1e8449; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand;" text="Proveedores" />
                <Button onAction="#loadEmployeesTab" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #6c3483; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand;" text="Empleados" />
                <Button onAction="#loadClientsTab" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #1f618d; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand;" text="Clientes" />
                <Button onAction="#loadInventoryTab" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #922b21; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand;" text="Inventario" />
                <Button onAction="#abrirRepositorioGithub" prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #4e1eb8; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand;" text="Repositorio" />
            </HBox>
            
        </VBox>
    </top>

    <center>
        <StackPane fx:id="tabContainer" style="-fx-background-color: #1E1E1E; -fx-padding: 20;" BorderPane.alignment="CENTER">
            <children>
            <StackPane prefHeight="150.0" prefWidth="200.0">
               <children>
                  <ImageView disable="true" mouseTransparent="true" opacity="0.29" pickOnBounds="true" preserveRatio="true" StackPane.alignment="BOTTOM_RIGHT">
                     <image>
                        <Image url="@../mediafiles/usuario.png" />
                     </image>
                     <cursor>
                        <Cursor fx:constant="DEFAULT" />
                     </cursor>
                  </ImageView>
                      
                      <ScrollPane fitToWidth="true" styleClass="scroll-pane" style="-fx-background-color: transparent; -fx-background: transparent;">
                         <content>
                      <VBox alignment="TOP_LEFT" maxWidth="850.0" prefHeight="528.0" prefWidth="850.0" spacing="20.0">
                          
                          <!-- Textos de cabecera -->
                          <Label style="-fx-text-fill: #E0E0E0; -fx-font-size: 16px; -fx-font-weight: bold;" text="Detalles técnicos.">
                              <font>
                                  <Font size="36.0" />
                              </font>
                          </Label>
                          
                          <Label style="-fx-text-fill: #A0A0A0; -fx-font-size: 12px; -fx-line-spacing: 5px;" text="Este proyecto es un sistema de escritorio desarrollado en Java. La interfaz gráfica está construida utilizando JavaFX y FXML, implementando estilos modernos mediante CSS para ofrecer una experiencia de usuario fluida y eficiente." textAlignment="JUSTIFY" wrapText="true" />
                          
                          <Label prefHeight="60.0" prefWidth="800.0" style="-fx-text-fill: #A0A0A0; -fx-font-size: 12px; -fx-line-spacing: 5px;" text="Se emplea PostgreSQL de forma embebida para garantizar la persistencia de datos y la facilidad de despliegue sin configuraciones externas complejas. La aplicación sigue el patrón Modelo-Vista-Controlador (MVC), separando el diseño visual de la lógica de negocio y el acceso a la base de datos." textAlignment="JUSTIFY" wrapText="true" />
            
                          <!-- Línea sutil separadora -->
                          <Separator style="-fx-background-color: transparent; -fx-border-color: #333333; -fx-border-width: 1 0 0 0;" />
                          
                          <Label prefHeight="27.0" prefWidth="167.0" style="-fx-font-weight: bold;" text="Resumen Nominal" textFill="WHITE">
                              <font>
                                  <Font size="18.0" />
                              </font>
                          </Label>
                          
                          <!-- NUEVO: Único contenedor HBox para las 3 tarjetas alineadas en fila -->
                          <HBox alignment="CENTER_LEFT" prefHeight="156.0" prefWidth="825.0" spacing="20.0">
                              
                              <!-- Tarjeta Proveedores (Borde Verde) -->
                              <VBox fx:id="cardProveedores" alignment="CENTER" prefHeight="142.0" prefWidth="250.0">
                                  <Label style="-fx-font-size: 13px; -fx-text-fill: #A0A0A0;" text="Proveedores" />
                                  <Label fx:id="lblTotalProveedores" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #E0E0E0;" text="0" />
                           <styleClass>
                              <String fx:value="dashboard-card" />
                              <String fx:value="card-proveedor" />
                           </styleClass>
                           <HBox.margin>
                              <Insets left="10.0" />
                           </HBox.margin>
                           <padding>
                              <Insets top="5.0" />
                           </padding>
                              </VBox>
            
                              <!-- Tarjeta Empleados (Borde Morado) -->
                              <VBox fx:id="cardEmpleados" alignment="CENTER" prefHeight="90.0" prefWidth="250.0" styleClass="dashboard-card, card-empleado">
                                  <Label style="-fx-font-size: 13px; -fx-text-fill: #A0A0A0;" text="Empleados" />
                                  <Label fx:id="lblTotalEmpleados" prefHeight="40.0" prefWidth="0.0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #E0E0E0;" text="0" />
                           <padding>
                              <Insets left="5.0" right="5.0" top="5.0" />
                           </padding>
                           <HBox.margin>
                              <Insets left="10.0" />
                           </HBox.margin>
                              </VBox>
            
                              <!-- Tarjeta Clientes (Borde Azul) -->
                              <VBox fx:id="cardClientes" alignment="CENTER" prefHeight="90.0" prefWidth="250.0" styleClass="dashboard-card, card-cliente">
                                  <Label style="-fx-font-size: 13px; -fx-text-fill: #A0A0A0;" text="Clientes" />
                                  <Label fx:id="lblTotalClientes" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #E0E0E0;" text="0" />
                           <HBox.margin>
                              <Insets left="10.0" />
                           </HBox.margin>
                           <padding>
                              <Insets top="5.0" />
                           </padding>
                              </VBox>
                        <padding>
                           <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                        </padding>
            
                          </HBox>
                          
                      </VBox>
                         </content>
                      </ScrollPane>
               </children>
            </StackPane>
            </children>
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" prefHeight="30.0" style="-fx-background-color: #181818; -fx-padding: 5 20; -fx-border-color: #333333; -fx-border-width: 1 0 0 0;" BorderPane.alignment="CENTER">
            <Label fx:id="lblInfo" style="-fx-text-fill: #888888; -fx-font-size: 12px;" text="Listo. Sistema iniciado." />
        </HBox>
    </bottom>

</BorderPane>
