<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="900.0" stylesheets="@../Styles/table.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.PrincipalView">
    
    <top>
        <VBox spacing="15.0" style="-fx-background-color: #181818; -fx-padding: 20; -fx-border-color: #333333; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
            
            <Label text="Sistema Administrativo para Gestión de Nóminas" style="-fx-text-fill: #E0E0E0; -fx-font-size: 22px; -fx-font-weight: bold;" />
            
            <Separator style="-fx-background-color: transparent; -fx-border-color: #333333; -fx-border-width: 1 0 0 0;" />
            
            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <Button onAction="#loadProvidersTab" prefHeight="35.0" prefWidth="160.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 6; -fx-cursor: hand;" text="Proveedores" />
                <Button onAction="#cargarTab3" prefHeight="35.0" prefWidth="160.0" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 6; -fx-cursor: hand;" text="Empleados" />
                <Button onAction="#loadClientsTab" prefHeight="35.0" prefWidth="160.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 6; -fx-cursor: hand;" text="Clientes" />
                <Button prefHeight="35.0" prefWidth="160.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 6; -fx-cursor: hand;" text="Inventario" />
            </HBox>
            
        </VBox>
    </top>

    <center>
        <StackPane fx:id="tabContainer" style="-fx-background-color: #121212; -fx-padding: 30;" BorderPane.alignment="CENTER">
            <children>
                
                <VBox spacing="15.0" maxWidth="800.0" alignment="TOP_LEFT">
                    
                    <Label text="Detalles técnicos." style="-fx-text-fill: #E0E0E0; -fx-font-size: 18px; -fx-font-weight: bold;" />
                    
                    <Label text="Lorem ipsum dolor sit, amet consectetur adipiscing elit, dictum venenatis. Nostra viverra dui sociis tincidunt risus ac magna orci tellus, mi maecenas justo habitasse semper platea netus sagittis, mauris ultrices tempor in a dictum fusce quisque. Primis a justo iaculis nisl ante scelerisque, sed fusce turpis sociosqu senectus, venenatis penatibus suspendisse duis curae. Montes ante parturient eleifend natoque inceptos cursus praesent fames torquent auctor nunc arcu ridiculus duis." textAlignment="JUSTIFY" wrapText="true" style="-fx-text-fill: #A0A0A0; -fx-font-size: 14px; -fx-line-spacing: 4px;" />
                    
                    <Label text="Congue arcu cras ridiculus dui varius curae mi morbi, facilisis commodo vel tristique facilisi vitae. Est justo suspendisse egestas dapibus diam venenatis ac, ultrices nulla porta parturient platea erat aptent sociosqu, fames litora tortor donec ligula arcu." textAlignment="JUSTIFY" wrapText="true" style="-fx-text-fill: #A0A0A0; -fx-font-size: 14px; -fx-line-spacing: 4px;" />
                    
                </VBox>
                
            </children>
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" prefHeight="30.0" style="-fx-background-color: #181818; -fx-padding: 5 20; -fx-border-color: #333333; -fx-border-width: 1 0 0 0;" BorderPane.alignment="CENTER">
            <Label fx:id="lblInfo" text="Listo. Sistema iniciado." style="-fx-text-fill: #888888; -fx-font-size: 12px;" />
        </HBox>
    </bottom>

</BorderPane>